# Full-Web update bridge configuration

FULL_WEB_MEDIACRAWLER_ROOT=/absolute/path/to/MediaCrawler
FULL_WEB_MEDIACRAWLER_PYTHON=/absolute/path/to/MediaCrawler/.venv/bin/python
FULL_WEB_MEDIACRAWLER_ENV_FILE=/absolute/path/to/MediaCrawler/.env

FULL_WEB_WB_UPDATE_COMMAND="{python} -m full_web_sidecar.update_bridge --platform wb --week-start {week_start} --week-end {week_end} --db-path {db_path}"
FULL_WEB_FB_UPDATE_COMMAND="{python} -m full_web_sidecar.update_bridge --platform fb --week-start {week_start} --week-end {week_end} --db-path {db_path}"

FULL_WEB_WB_SAVE_ROOT=/absolute/path/to/Grad-Project/data/full_web_sources/wb
FULL_WEB_WB_CRAWL_STRATEGY=auto
FULL_WEB_WB_KEYWORD_MODE=regular
FULL_WEB_WB_KEYWORDS=
FULL_WEB_WB_LOGIN_TYPE=qrcode
FULL_WEB_WB_PAGE_LIMIT=50
FULL_WEB_WB_HEADLESS=false
FULL_WEB_WB_GET_COMMENTS=false
FULL_WEB_WB_GET_SUB_COMMENTS=false
FULL_WEB_WB_FORCE_LOGIN=false
FULL_WEB_WB_KEYWORD_EARLY_STOP=true
FULL_WEB_WB_KEYWORD_EARLY_STOP_PAGES=5
FULL_WEB_WB_KEYWORD_EARLY_STOP_MIN_IN_WINDOW=1

FULL_WEB_FB_OUTPUT_ROOT=/absolute/path/to/Grad-Project/data/full_web_sources/apify
FULL_WEB_FB_RESULTS_LIMIT=20
FULL_WEB_FB_KEYWORDS_CONFIG=/absolute/path/to/MediaCrawler/config/facebook_weekly_keyword_groups.json
